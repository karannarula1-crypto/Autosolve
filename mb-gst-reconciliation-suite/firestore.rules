// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User email
//   - role: string (required) - enum ['admin', 'portal_action', 'view_only']
//   - isAuthorized: bool (required) - Admin authorization status
//   - displayName: string (optional) - User name
//   - photoURL: string (optional) - User photo
//   - createdAt: timestamp (optional) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || 
         (request.auth.token.email == "karan.narula1@magicbricks.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'isAuthorized']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'portal_action', 'view_only'] &&
             data.isAuthorized is bool;
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['type', 'title', 'userEmail', 'userId', 'timestamp']) &&
             data.type in ['upload', 'email', 'report', 'auth'] &&
             data.title is string &&
             data.userEmail is string &&
             data.userId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /activity/{activityId} {
      // Everyone authorized can read activity
      allow read: if isAuthenticated() && getUserData().isAuthorized == true;
      // Authorized users can create activity logs
      allow create: if isAuthenticated() && getUserData().isAuthorized == true && isValidActivity(request.resource.data);
      // Only Admins can delete activity logs
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile. Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile on first login, but cannot set themselves as admin or authorized (unless bootstrap)
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (
                      (request.resource.data.email == "karan.narula1@magicbricks.com" && request.resource.data.role == "admin" && request.resource.data.isAuthorized == true) ||
                      (request.resource.data.role == "view_only" && request.resource.data.isAuthorized == false)
                    );
      
      // Admins can update any user's role and authorization status.
      // Users can update their own displayName and photoURL, but not role or isAuthorized.
      allow update: if isAdmin() || 
                    (isOwner(userId) && 
                     isValidUser(request.resource.data) &&
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.isAuthorized == resource.data.isAuthorized &&
                     request.resource.data.email == resource.data.email);
    }
  }
}
