{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user with role-based access control",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "portal_action", "view_only"], "description": "User role" },
        "isAuthorized": { "type": "boolean", "description": "Whether the user is authorized by an admin" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role", "isAuthorized"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Log of system actions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["upload", "email", "report", "auth"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "userEmail": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["type", "title", "userEmail", "userId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and permissions"
    },
    "/activity/{activityId}": {
      "schema": "Activity",
      "description": "System activity logs"
    }
  }
}
